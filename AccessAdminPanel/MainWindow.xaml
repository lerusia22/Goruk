<Window x:Class="AccessAdminPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AccessAdminPanel"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Admin Panel" WindowState="Maximized" MinWidth="1200" MinHeight="200">
    <Grid Background="Gray">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

            <ListView BorderBrush="Transparent" HorizontalAlignment="Left" x:Name="EmployesList" Foreground="White" FontSize="15" MinWidth="150" Background="Transparent"/>
            <ListView BorderBrush="Transparent" HorizontalAlignment="Center" x:Name="CheckpointList" Foreground="White" FontSize="15" MinWidth="150" Background="Transparent"/>
            <ListView BorderBrush="Transparent" HorizontalAlignment="Right" x:Name="LogsList" Foreground="White" FontSize="15" MinWidth="150" Background="Transparent"/>
    </Grid>
</Window>
