<Window x:Class="UserAccessClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UserAccessClient"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="KosikovProgramm" Height="500" Width="900">
    <Grid Background="Gray">

        <TextBlock Foreground="WhiteSmoke" Margin="362,101,362,351" Width="175" Height="32" Text="ФИО" FontSize="16" TextAlignment="Center"/>
        <TextBlock Foreground="WhiteSmoke" Margin="388,193,387,259" Width="125" Height="32" Text="подразделение" FontSize="16" TextAlignment="Center"/>
        <TextBlock Foreground="WhiteSmoke" Margin="362,275,362,177" Width="175" Height="32" Text="пропускной пункт" FontSize="16" TextAlignment="Center"/>

        <TextBox x:Name="TextBoxFIO" Width="175" TextWrapping="WrapWithOverflow" TextAlignment="Center" FontSize="13" Padding="0 10" Height="55" Margin="363,215,362,214"/>
        <TextBox x:Name="TextBoxDepartment" Height="55" TextAlignment="Center" FontSize="13" Padding="0 10" Margin="363,133,362,296"/>
        <ComboBox x:Name="ComboBoxPunkt" FontSize="13" Width="175" Height="55" Margin="363,298,362,131"/>

        <Button Width="125" Height="45" Content="Войти" FontSize="20" Click="Button_Click" VerticalAlignment="Bottom" Margin="742,0,33,10" BorderBrush="Black"/>
        <TextBlock x:Name="errortext" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 310 0 0" Foreground="White" Text="Введите данные"/>

    </Grid>
</Window>
